# Application
PORT=3000
NODE_ENV=development

# Database (MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=tuktuk_tracking
DB_USER=root
DB_PASSWORD=yourpassword

# JWT Secrets
JWT_ACCESS_SECRET=your_super_secret_access_key_here_min_32_chars
JWT_REFRESH_SECRET=your_super_secret_refresh_key_here_min_32_chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Sentry (get from sentry.io)
SENTRY_DSN=https://yourkey@o123.ingest.sentry.io/projectid

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
DEVICE_RATE_LIMIT_MAX=200

# API
API_VERSION=v1