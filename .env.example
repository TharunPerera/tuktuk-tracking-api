# Application
PORT=3000
NODE_ENV=development

# Database (MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=tuktuk_tracking
DB_USER=root
DB_PASSWORD=YOUR_MYSQL_PASSWORD_HERE

# JWT Secrets (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
JWT_ACCESS_SECRET=GENERATE_A_RANDOM_32_CHAR_STRING_HERE
JWT_REFRESH_SECRET=GENERATE_A_DIFFERENT_RANDOM_32_CHAR_STRING_HERE
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Sentry (get DSN from sentry.io → Your Project → Settings → Client Keys)
SENTRY_DSN=https://YOUR_KEY@YOUR_ORG.ingest.sentry.io/YOUR_PROJECT_ID

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
DEVICE_RATE_LIMIT_MAX=200

# API
API_VERSION=v1